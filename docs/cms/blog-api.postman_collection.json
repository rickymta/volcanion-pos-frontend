{
  "info": {
    "_postman_id": "blog-public-api-collection-v1",
    "name": "CMS — Blog Public API",
    "description": "Bộ request đầy đủ cho Blog Public API (không cần xác thực):\n- Posts: danh sách, featured, chi tiết theo slug\n- Categories, Tags\n- Pricing plans, Testimonials, FAQs\n- Static pages, Site settings\n- Contact form\n\n## Hướng dẫn sử dụng\n1. Cập nhật biến `baseUrl` (mặc định `http://localhost:5003`).\n2. Tất cả endpoint đều public, không cần token.\n\n## Caching\n| Endpoint | Duration |\n|----------|----------|\n| Posts list, detail | 60s |\n| Featured posts | 120s |\n| Categories, Tags, FAQs | 120s |\n| Pricing, Testimonials | 300s |\n| Settings, Pages | 600s |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5003", "type": "string" },
    { "key": "postSlug", "value": "gioi-thieu-pos-pro", "type": "string" },
    { "key": "pageSlug", "value": "chinh-sach-bao-mat", "type": "string" }
  ],
  "auth": { "type": "noauth" },
  "item": [
    {
      "name": "📝 Posts",
      "description": "Bài viết công khai (chỉ Published).\nRoute: /api/v1/posts",
      "item": [
        {
          "name": "Danh sách bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has items', () => pm.expect(res.items).to.be.an('array'));",
                  "pm.test('Has totalCount', () => pm.expect(res).to.have.property('totalCount'));",
                  "if (res.items.length > 0) {",
                  "    pm.collectionVariables.set('postSlug', res.items[0].slug);",
                  "    console.log('✅ postSlug saved:', res.items[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "posts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "categorySlug", "value": "", "disabled": true },
                { "key": "tagSlug", "value": "", "disabled": true }
              ]
            },
            "description": "Danh sách bài viết Published (phân trang). Lọc theo search, categorySlug, tagSlug.\nResponse cache: 60 giây."
          }
        },
        {
          "name": "Bài viết nổi bật (featured)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts/featured",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "posts", "featured"]
            },
            "description": "Danh sách bài viết được đánh dấu featured (tối đa 10).\nResponse cache: 120 giây."
          }
        },
        {
          "name": "Chi tiết bài viết (theo slug)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Has content', () => pm.expect(res).to.have.property('content'));",
                  "pm.test('Has categories', () => pm.expect(res.categories).to.be.an('array'));",
                  "pm.test('Has tags', () => pm.expect(res.tags).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/posts/{{postSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "posts", "{{postSlug}}"]
            },
            "description": "Chi tiết bài viết theo slug (tự động tăng view count).\nResponse cache: 60 giây."
          }
        }
      ]
    },
