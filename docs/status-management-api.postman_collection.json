    {
      "name": "🏢 Tenant Management (TenantStatus)",
      "description": "Các endpoint bị ảnh hưởng bởi việc chuyển Tenant.Status từ string sang TenantStatus enum.\nStatus hợp lệ: Inactive | Active | Suspended | Provisioning | Failed",
      "item": [
        {
          "name": "GET /tenants — List All",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has items array', () => pm.expect(json.items || json.data).to.be.an('array'));",
                  "const tenants = json.items || json.data || [];",
                  "if (tenants.length > 0) {",
                  "  pm.test('Each tenant has Status field', () => {",
                  "    tenants.forEach(t => pm.expect(t.status ?? t.Status).to.be.a('string'));",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{sysadmin_base_url}}/super/v1/tenants?page=1&pageSize=20",
              "host": ["{{sysadmin_base_url}}"],
              "path": ["super", "v1", "tenants"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true, "description": "TenantStatus enum: Active | Inactive | Suspended | Provisioning | Failed" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{sysadmin_token}}" }
            ]
          }
        },
        {
          "name": "GET /tenants?status=Active — Filter Active",
