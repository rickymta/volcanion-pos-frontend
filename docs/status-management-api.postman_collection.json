    {
      "name": "🔐 SysAdmin Auth",
      "item": [
        {
          "name": "Login (SysAdmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('accessToken present', () => pm.expect(json.accessToken || json.AccessToken).to.be.a('string'));",
                  "const token = json.accessToken || json.AccessToken;",
                  "pm.collectionVariables.set('sysadmin_token', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{sysadmin_base_url}}/super/v1/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"SuperAdmin@123\"\n}"
            }
          }
        }
      ]
