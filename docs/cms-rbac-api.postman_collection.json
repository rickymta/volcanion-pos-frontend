              "raw": "{{baseUrl}}/api/v1/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"]
            },
            "description": "Editor không có permission `users.read` → expect 403 Forbidden."
          }
        },
        {
          "name": "Editor — DELETE post (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));",
                  "console.log('✅ Editor correctly blocked from posts.delete');"
                ]
              }
            }
          ],
          "request": {
