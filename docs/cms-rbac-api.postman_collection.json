            "description": "Đăng nhập bằng Editor để kiểm tra quyền hạn bị giới hạn.\n\nLưu ý: chạy **Tạo user mới** (Editor) trước để có tài khoản này."
          }
        },
        {
          "name": "Editor — GET users (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));",
                  "console.log('✅ Editor correctly blocked from users.read');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{editorToken}}", "type": "string" }]
            },
            "method": "GET",
