    {
      "name": "🎭 Roles",
      "description": "Xem danh sách role và permissions được gán.\nRoute: /api/v1/admin/roles\nQuyền cần có: users.read",
      "item": [
        {
          "name": "Danh sách roles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Is array', () => pm.expect(res).to.be.an('array'));",
                  "pm.test('Has system roles', () => {",
                  "    const names = res.map(r => r.name);",
                  "    pm.expect(names).to.include('Admin');",
                  "    pm.expect(names).to.include('Editor');",
                  "    pm.expect(names).to.include('Support');",
                  "});",
                  "// Save first non-system or any role ID for tests",
                  "const editorRole = res.find(r => r.name === 'Editor');",
                  "if (editorRole) {",
                  "    pm.collectionVariables.set('roleId', editorRole.id);",
                  "    console.log('✅ roleId (Editor) saved:', editorRole.id);",
                  "}",
                  "res.forEach(r => console.log(`[${r.name}] permissions: ${r.permissions.join(', ')}`));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "roles"]
            },
            "description": "Lấy danh sách tất cả roles, kèm danh sách permission codes được gán cho từng role.\n\nQuyền: `users.read`\n\nResponse ví dụ:\n```json\n[\n  {\n    \"id\": \"...\",\n    \"name\": \"Admin\",\n    \"description\": \"Full access\",\n    \"isSystem\": true,\n    \"permissions\": [\"posts.read\", \"posts.write\", ...]\n  },\n  ...\n]\n```"
          }
        },
        {
          "name": "Xem permissions của Admin role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const admin = res.find(r => r.name === 'Admin');",
                  "pm.test('Admin role exists', () => pm.expect(admin).to.not.be.undefined);",
                  "pm.test('Admin has users.delete', () => pm.expect(admin.permissions).to.include('users.delete'));",
                  "pm.test('Admin has posts.delete', () => pm.expect(admin.permissions).to.include('posts.delete'));",
                  "pm.test('Admin has settings.write', () => pm.expect(admin.permissions).to.include('settings.write'));",
                  "console.log('Admin permissions count:', admin?.permissions.length);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "roles"]
            },
            "description": "Gọi cùng endpoint nhưng test script kiểm tra cụ thể permissions của role Admin."
          }
        },
        {
          "name": "Xem permissions của Editor role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const editor = res.find(r => r.name === 'Editor');",
                  "pm.test('Editor role exists', () => pm.expect(editor).to.not.be.undefined);",
                  "pm.test('Editor has posts.write', () => pm.expect(editor.permissions).to.include('posts.write'));",
                  "pm.test('Editor does NOT have posts.delete', () => pm.expect(editor.permissions).to.not.include('posts.delete'));",
                  "pm.test('Editor does NOT have users.read', () => pm.expect(editor.permissions).to.not.include('users.read'));",
                  "pm.test('Editor does NOT have settings.write', () => pm.expect(editor.permissions).to.not.include('settings.write'));",
                  "console.log('Editor permissions:', editor?.permissions.join(', '));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "roles"]
            },
            "description": "Gọi cùng endpoint nhưng test script kiểm tra cụ thể permissions của role Editor."
          }
        },
        {
          "name": "Xem permissions của Support role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "const support = res.find(r => r.name === 'Support');",
                  "pm.test('Support role exists', () => pm.expect(support).to.not.be.undefined);",
                  "pm.test('Support has contacts.read', () => pm.expect(support.permissions).to.include('contacts.read'));",
                  "pm.test('Support has contacts.update', () => pm.expect(support.permissions).to.include('contacts.update'));",
                  "pm.test('Support does NOT have posts.write', () => pm.expect(support.permissions).to.not.include('posts.write'));",
                  "pm.test('Support does NOT have users.read', () => pm.expect(support.permissions).to.not.include('users.read'));",
                  "console.log('Support permissions:', support?.permissions.join(', '));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "roles"]
            },
            "description": "Gọi cùng endpoint nhưng test script kiểm tra cụ thể permissions của role Support."
          }
        }
      ]
    },
    {
      "name": "🔑 Permissions",
      "description": "Xem toàn bộ permission codes trong hệ thống.\nRoute: /api/v1/admin/permissions\nQuyền cần có: users.read",
      "item": [
        {
          "name": "Danh sách permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Is array', () => pm.expect(res).to.be.an('array'));",
                  "pm.test('Has 18 permissions', () => pm.expect(res).to.have.lengthOf(18));",
                  "pm.test('Has posts group', () => pm.expect(res.some(p => p.group === 'Posts')).to.be.true);",
                  "pm.test('Has users group', () => pm.expect(res.some(p => p.group === 'Users')).to.be.true);",
                  "// In danh sách permissions theo group",
                  "const byGroup = {};",
                  "res.forEach(p => { byGroup[p.group] = byGroup[p.group] || []; byGroup[p.group].push(p.code); });",
                  "Object.entries(byGroup).forEach(([g, codes]) => console.log(`[${g}]`, codes.join(', ')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/permissions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "permissions"]
            },
            "description": "Lấy toàn bộ permission codes được định nghĩa trong hệ thống, phân nhóm theo `group`.\n\nQuyền: `users.read`\n\nDanh sách permissions hiện tại (18):\n\n**Posts**: `posts.read`, `posts.write`, `posts.publish`, `posts.delete`\n**Categories**: `categories.write`\n**Tags**: `tags.write`\n**Media**: `media.upload`, `media.delete`\n**Pages**: `pages.write`\n**FAQs**: `faqs.write`\n**Contacts**: `contacts.read`, `contacts.update`\n**Testimonials**: `testimonials.write`\n**Pricing**: `pricing.write`\n**Settings**: `settings.write`\n**Users**: `users.read`, `users.write`, `users.delete`"
          }
        }
      ]
    },
